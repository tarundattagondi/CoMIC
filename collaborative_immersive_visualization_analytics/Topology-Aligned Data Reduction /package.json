{
  "name": "civa-reduction",
  "version": "0.0.0",
  "description": "CIVA point cloud analysis and reduction tool",
  "type": "module",
  "engines": {
    "node": "18.20.7"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json}\" \"*.{json,md}\""
  },
  "dependencies": {
    "@kitware/vtk.js": "^30.7.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.1.0",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^5.4.21"
  }
}
